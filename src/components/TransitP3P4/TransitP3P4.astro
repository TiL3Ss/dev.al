---
import styles from './TransitP3P4.module.css';
---

<div class={styles.transit}>

  <!-- Capa base: ruido estático -->
  <div class={styles.static}></div>

  <!-- Scanlines -->
  <div class={styles.scanlines}></div>

  <!-- Interferencia RGB / glitch -->
  <div class={styles.glitchR}></div>
  <div class={styles.glitchG}></div>
  <div class={styles.glitchB}></div>

  <!-- Barras arcoíris que irrumpen desde abajo -->
  <div class={styles.rainbowBars}>
    <div class={styles.rb1}></div>
    <div class={styles.rb2}></div>
    <div class={styles.rb3}></div>
    <div class={styles.rb4}></div>
    <div class={styles.rb5}></div>
    <div class={styles.rb6}></div>
    <div class={styles.rb7}></div>
  </div>

  <!-- Línea de señal horizontal animada -->
  <div class={styles.hline}></div>

  <!-- Texto de canal -->
  <div class={styles.channelTag}>MIDNIGHT CHANNEL · CH·04</div>

</div>